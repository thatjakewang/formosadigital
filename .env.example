# Flask Configuration
FLASK_DEBUG=False

# Pre-launch kill switch: True = every page gets noindex (meta tag + X-Robots-Tag header).
# Set to False when the site is ready to be indexed.
NOINDEX=True

# Site Configuration
# The canonical public URL of your site (used for sitemap, canonical links, JSON-LD)
SITE_URL=https://formosadigital.com
